@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin dashboard";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Admin dashboard</h1>
        <p class="page-subtitle">Manage courses and accounts for the Academic Document RAG System.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="form-card">
            <div class="page-subtitle">Courses</div>
            <div class="page-title" style="font-size:2rem;">@Model.CourseCount</div>
            <div class="cell-muted">@Model.ActiveCourseCount active</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-card">
            <div class="page-subtitle">Accounts</div>
            <div class="page-title" style="font-size:2rem;">@Model.AccountCount</div>
            <div class="cell-muted">@Model.TeacherCount lecturers</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="form-card h-100">
            <h3 class="page-title" style="font-size:1.2rem;">Course management</h3>
            <p class="page-subtitle">Create, edit, delete and search courses. Changes broadcast live to lecturers.</p>
            <a asp-page="/Courses/Index" class="btn btn-primary">Open courses</a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="form-card h-100">
            <h3 class="page-title" style="font-size:1.2rem;">Account management</h3>
            <p class="page-subtitle">Create student and lecturer accounts. New lecturers are emailed their credentials.</p>
            <a asp-page="/Accounts/Index" class="btn btn-primary">Open accounts</a>
        </div>
    </div>
</div>
