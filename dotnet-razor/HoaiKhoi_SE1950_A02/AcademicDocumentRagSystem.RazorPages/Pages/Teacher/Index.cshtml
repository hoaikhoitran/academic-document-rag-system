@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Teacher.IndexModel
@{
    ViewData["Title"] = "Lecturer dashboard";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Welcome, @Model.FullName</h1>
        <p class="page-subtitle">
            Lecturer dashboard.
            @if (!string.IsNullOrWhiteSpace(Model.CourseDisplay))
            {
                <text>Assigned course: <span class="meta-badge meta-badge--accent">@Model.CourseDisplay</span></text>
            }
            else
            {
                <text>No course has been assigned to your account yet. Please contact your administrator.</text>
            }
        </p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="form-card h-100">
            <h3 class="page-title" style="font-size:1.1rem;">Live courses</h3>
            <p class="page-subtitle">Course list that updates in real time via SignalR when admins make changes.</p>
            <a asp-page="/Teacher/Courses" class="btn btn-primary">Open live courses</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-card h-100">
            <h3 class="page-title" style="font-size:1.1rem;">Documents</h3>
            <p class="page-subtitle">Upload course material and track its RAG index status.</p>
            <div class="action-bar">
                <a asp-page="/Documents/Upload" class="btn btn-primary">Upload</a>
                <a asp-page="/Documents/Index" class="btn btn-outline-primary">My Documents</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-card h-100">
            <h3 class="page-title" style="font-size:1.1rem;">Ask RAG</h3>
            <p class="page-subtitle">Ask grounded questions about your indexed documents.</p>
            <a asp-page="/Chat/Index" class="btn btn-primary">Open Chatbot</a>
        </div>
    </div>
</div>
