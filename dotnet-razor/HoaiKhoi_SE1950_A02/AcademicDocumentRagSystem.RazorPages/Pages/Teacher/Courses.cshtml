@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Teacher.CoursesModel
@{
    ViewData["Title"] = "Live courses";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Course catalogue</h1>
        <p class="page-subtitle">
            This list updates automatically when an administrator changes a course
            <span id="live-indicator" class="meta-badge">live</span>
        </p>
    </div>
</div>

<div id="course-list" data-refresh-url="@Url.Page("/Teacher/Courses", "Table")">
    <partial name="_CourseTable" model="Model.Courses" />
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/course-realtime.js" asp-append-version="true"></script>
}
