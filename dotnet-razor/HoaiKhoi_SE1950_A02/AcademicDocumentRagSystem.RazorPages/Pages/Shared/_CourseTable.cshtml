@model List<AcademicDocumentRagSystem.Services.DTOs.Courses.CourseDto>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <h3>No courses yet</h3>
        <p>Courses created by an administrator will appear here automatically.</p>
    </div>
}
else
{
    <div class="table-wrap">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td class="cell-strong">@course.Code</td>
                            <td>@course.Name</td>
                            <td class="cell-muted">@course.Description</td>
                            <td>
                                @if (course.Status)
                                {
                                    <span class="status-badge status-badge--active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-badge--inactive">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
