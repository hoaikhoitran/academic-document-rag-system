@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Academic Document RAG (Razor)</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    @{
        var email = Context.Session.GetString(SessionKeys.Email);
        var roleName = Context.Session.GetString(SessionKeys.RoleName);
    }

    <header>
        <nav class="app-navbar navbar navbar-expand-md">
            <div class="container-fluid app-shell" style="padding-top:.6rem;padding-bottom:.6rem;">
                <a class="navbar-brand" href="/">
                    <span class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 4a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z" />
                            <path d="M14 2v6h6" />
                            <path d="M9 13h6M9 17h4" />
                        </svg>
                    </span>
                    Academic Document RAG
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-md-4">
                        @if (email != null)
                        {
                            if (roleName == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Admin/Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Accounts/Index">Accounts</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Courses/Index">Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Documents/All">Documents</a>
                                </li>
                            }

                            if (roleName == "Teacher")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Teacher/Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Teacher/Courses">Live Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Documents/Upload">Upload Document</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Documents/Index">My Documents</a>
                                </li>
                            }

                            if (roleName == "Teacher" || roleName == "Student")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Chat/Index">Ask RAG</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Chat/Sessions">Chat History</a>
                                </li>
                            }

                            if (roleName == "Student")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Student/Index">Dashboard</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-md-center gap-md-2">
                        @if (email != null)
                        {
                            <li class="nav-item">
                                <span class="nav-user">
                                    <span class="nav-user__name">@Context.Session.GetString(SessionKeys.FullName)</span>
                                    <span class="nav-user__role">@roleName</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm" asp-page="/Auth/Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-page="/Auth/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="app-main">
        <div class="app-shell">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="app-shell d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>&copy; 2026 Academic Document RAG System — Razor Pages (PRN222 A02)</span>
            <span>Retrieval-augmented answers grounded in your course documents.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
