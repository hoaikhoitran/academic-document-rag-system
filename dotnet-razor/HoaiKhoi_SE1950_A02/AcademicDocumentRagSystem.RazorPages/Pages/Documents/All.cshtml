@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Documents.AllModel
@{
    ViewData["Title"] = "All documents";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">All Documents</h1>
        <p class="page-subtitle">Every uploaded document across all courses, with its index status and uploader.</p>
    </div>
</div>

<div class="form-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label" for="CourseId">Course</label>
            <select id="CourseId" name="CourseId" class="form-control">
                <option value="">All courses</option>
                @foreach (var course in Model.Courses)
                {
                    <option value="@course.CourseId" selected="@(Model.CourseId == course.CourseId)">@course.Code - @course.Name</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label" for="IndexStatus">Index status</label>
            <select id="IndexStatus" name="IndexStatus" class="form-control">
                <option value="">All</option>
                <option value="Indexed" selected="@(Model.IndexStatus == "Indexed")">Indexed</option>
                <option value="Pending" selected="@(Model.IndexStatus == "Pending")">Pending</option>
                <option value="Failed" selected="@(Model.IndexStatus == "Failed")">Failed</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a asp-page="/Documents/All" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>
</div>

@if (Model.Documents.Count == 0)
{
    <div class="empty-state">
        <h3>No documents found</h3>
        <p>No documents match the current filter.</p>
    </div>
}
else
{
    <div class="table-wrap">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Document</th>
                        <th>Course</th>
                        <th>Index</th>
                        <th>Chunks</th>
                        <th>Uploaded by</th>
                        <th>Uploaded at</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var document in Model.Documents)
                    {
                        <tr>
                            <td class="cell-strong">@document.Title</td>
                            <td><span class="meta-badge">@document.CourseCode</span></td>
                            <td>
                                @if (document.IndexStatus == "Indexed")
                                {
                                    <span class="status-badge status-badge--active">Indexed</span>
                                }
                                else
                                {
                                    <span class="status-badge status-badge--inactive">@document.IndexStatus</span>
                                }
                            </td>
                            <td class="cell-id">@document.TotalChunks</td>
                            <td class="cell-muted">@document.SubmittedByDisplay</td>
                            <td class="cell-muted">@document.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (document.HasChunks)
                                {
                                    <a asp-page="/Documents/Details" asp-route-id="@document.DocumentId" class="btn btn-secondary btn-sm">Details</a>
                                }
                                else
                                {
                                    <span class="cell-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
