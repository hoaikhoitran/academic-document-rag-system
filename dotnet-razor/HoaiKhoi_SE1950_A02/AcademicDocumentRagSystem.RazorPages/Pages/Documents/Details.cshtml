@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Document details";
    var d = Model.Details;
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">@d.Title</h1>
        <p class="page-subtitle">
            <span class="meta-badge">@d.CourseCode</span>
            @if (!string.IsNullOrWhiteSpace(d.Chapter))
            {
                <span class="meta-badge meta-badge--accent">@d.Chapter</span>
            }
            <span class="cell-muted">@d.OriginalFileName · @d.FileType.ToUpperInvariant()</span>
        </p>
    </div>
    <div class="action-bar">
        @if (d.IndexStatus == "Indexed")
        {
            <a asp-page="/Chat/Ask" asp-route-documentId="@d.DocumentId" class="btn btn-primary">Ask about this document</a>
        }
        @if (d.CanReIndex)
        {
            <form method="post" asp-page-handler="Reindex" asp-route-id="@d.DocumentId" class="d-inline"
                  onsubmit="return confirm('Re-index this document? The chunk preview will be rebuilt.');">
                <button type="submit" class="btn btn-secondary">Re-index</button>
            </form>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="index-summary-grid">
    <div class="index-summary-card">
        <span class="index-summary-card__label">Index status</span>
        <strong>@d.IndexStatus</strong>
        <span>@(d.IndexedAt.HasValue ? d.IndexedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "Not indexed")</span>
    </div>
    <div class="index-summary-card">
        <span class="index-summary-card__label">Chunks</span>
        <strong>@d.TotalChunks</strong>
        <span>Retrieval units</span>
    </div>
    <div class="index-summary-card">
        <span class="index-summary-card__label">Uploaded by</span>
        <strong style="font-size:1rem;">@d.SubmittedByDisplay</strong>
        <span>@d.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(d.Description))
{
    <div class="form-card mb-4">
        <div class="chat-question__label">Description</div>
        <p>@d.Description</p>
    </div>
}

<h2 class="page-title" style="font-size:1.2rem; margin:1.5rem 0 1rem;">Chunk preview</h2>

@if (!string.IsNullOrWhiteSpace(d.PreviewMessage))
{
    <div class="alert alert-warning">@d.PreviewMessage</div>
}

@if (d.Chunks.Count == 0)
{
    <div class="empty-state">
        <h3>No chunk preview available</h3>
        <p>This document has no stored chunk preview rows.</p>
    </div>
}
else
{
    <div class="table-wrap mb-4">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Page</th>
                        <th>Chars</th>
                        <th>~Tokens</th>
                        <th>Text</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var chunk in d.Chunks)
                    {
                        <tr>
                            <td class="cell-id">@chunk.ChunkIndex</td>
                            <td class="cell-id">@(chunk.PageNumber?.ToString() ?? "-")</td>
                            <td class="cell-id">@chunk.CharCount</td>
                            <td class="cell-id">@(chunk.TokenEstimate?.ToString() ?? "-")</td>
                            <td><span class="source-text">@chunk.ChunkText</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (d.IndexLogs.Count > 0)
{
    <h2 class="page-title" style="font-size:1.2rem; margin:1.5rem 0 1rem;">Index history</h2>
    <div class="table-wrap">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Action</th>
                        <th>Status</th>
                        <th>Chunks</th>
                        <th>By</th>
                        <th>At</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in d.IndexLogs)
                    {
                        <tr>
                            <td class="cell-strong">@log.Action</td>
                            <td>@log.Status</td>
                            <td class="cell-id">@(log.TotalChunks?.ToString() ?? "-")</td>
                            <td class="cell-muted">@log.PerformedByEmail</td>
                            <td class="cell-muted">@log.PerformedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="cell-muted">@log.ErrorMessage</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="action-bar mt-4">
    <a asp-page="/Documents/Index" class="btn btn-secondary">Back to My Documents</a>
</div>
