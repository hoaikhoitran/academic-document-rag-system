@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Documents.UploadModel
@{
    ViewData["Title"] = "Upload Document";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Upload Document</h1>
        <p class="page-subtitle">
            Upload a course document and index it so the chatbot can answer from its content.
        </p>
    </div>
</div>

<div class="upload-workspace">
    <div class="form-card upload-form-card">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-section">
                <div class="form-section__title">Document info</div>

                <div class="form-field">
                    <label asp-for="Input.CourseId" class="form-label">Course</label>
                    <select asp-for="Input.CourseId" class="form-control">
                        @foreach (var course in Model.AvailableCourses)
                        {
                            <option value="@course.CourseId">@course.Code - @course.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Input.CourseId" class="text-danger"></span>
                    <span class="field-hint">You can only upload to your assigned course. Course creation is managed by Admin.</span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.Title" class="form-label">Title</label>
                    <input asp-for="Input.Title" class="form-control" placeholder="e.g. Lecture 1 - Introduction" />
                    <span asp-validation-for="Input.Title" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.File" class="form-label">File</label>
                    <label class="upload-dropzone" for="Input_File">
                        <span class="upload-dropzone__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 16V4" />
                                <path d="m7 9 5-5 5 5" />
                                <path d="M20 16.5V19a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-2.5" />
                            </svg>
                        </span>
                        <span>
                            <strong id="selected-file-name">Choose PDF, DOCX, PPTX, or TXT</strong>
                            <small>The file is uploaded, chunked, embedded, then indexed for retrieval.</small>
                        </span>
                    </label>
                    <input asp-for="Input.File" id="Input_File" type="file" class="upload-file-input" accept=".pdf,.docx,.pptx,.txt" />
                    <span asp-validation-for="Input.File" class="text-danger"></span>
                    <span class="field-hint">Teacher uploads are locked to the assigned course and auto-approved for indexing.</span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.Description" class="form-label">Description</label>
                    <textarea asp-for="Input.Description" class="form-control upload-description" placeholder="Optional notes about this document"></textarea>
                </div>

                <div class="form-field">
                    <label asp-for="Input.Chapter" class="form-label">Chapter</label>
                    <input asp-for="Input.Chapter" class="form-control" placeholder="e.g. Chapter 1" />
                </div>
            </div>

            <div class="form-actions upload-actions">
                <button type="submit" class="btn btn-primary upload-submit">Upload and Index</button>
                <a asp-page="/Chat/Index" class="btn btn-success">Go to Chatbot</a>
                <a asp-page="/Documents/Index" class="btn btn-secondary">My Documents</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const fileInput = document.getElementById("Input_File");
        const selectedFileName = document.getElementById("selected-file-name");
        fileInput?.addEventListener("change", () => {
            selectedFileName.textContent = fileInput.files?.[0]?.name || "Choose PDF, DOCX, PPTX, or TXT";
        });
    </script>
}
