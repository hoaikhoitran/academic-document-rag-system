@page
@using AcademicDocumentRagSystem.Services.DTOs.Documents
@model AcademicDocumentRagSystem.RazorPages.Pages.Chat.AskModel
@{
    ViewData["Title"] = "Ask a Question";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Ask a Question</h1>
        <p class="page-subtitle">Ask anything about the selected document. The answer cites the sources it used.</p>
        <span class="context-chip mt-2"><span>Document</span> #@Model.Input.DocumentId</span>
        @if (Model.Input.ChatSessionId.HasValue)
        {
            <span class="context-chip mt-2"><span>Session</span> #@Model.Input.ChatSessionId</span>
        }
    </div>
</div>

<div class="form-card" style="max-width:760px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input type="hidden" asp-for="Input.DocumentId" />
        <input type="hidden" asp-for="Input.ChatSessionId" />

        <div class="form-field">
            <label asp-for="Input.Question" class="form-label">Your question</label>
            <textarea asp-for="Input.Question" class="form-control" rows="4"
                      placeholder="e.g. Summarize the key concepts in this chapter."></textarea>
            <span asp-validation-for="Input.Question" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Ask</button>
            <a asp-page="/Chat/Index" class="btn btn-secondary">Back to Documents</a>
        </div>
    </form>
</div>

@if (Model.RagError != null)
{
    <div class="alert alert-danger mt-4">@Model.RagError</div>
}

@if (Model.Answer != null)
{
    <div class="surface-card mb-3 mt-4">
        <div class="chat-question__label">Your question</div>
        <p class="chat-question__text">@Model.Answer.Question</p>
    </div>

    <div class="surface-card mb-4">
        <div class="chat-question__label">Answer</div>
        <div class="chat-answer">@Model.Answer.Answer</div>
    </div>

    <h2 class="page-title" style="font-size:1.2rem; margin-bottom:1rem;">Sources</h2>

    @if (Model.Answer.Sources.Count == 0)
    {
        <div class="empty-state">
            <h3>No sources returned</h3>
            <p>This answer did not reference any specific passages from the document.</p>
        </div>
    }
    else
    {
        <div class="table-wrap mb-4">
            <div class="table-responsive-wrap">
                <table class="table-modern">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Page</th>
                            <th>Chunk</th>
                            <th>Uploaded by</th>
                            <th>Text</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var source in Model.Answer.Sources)
                        {
                            var uploader = UploaderDisplay.Format(source.UploadedByFullName, source.UploadedByEmail);
                            <tr>
                                <td class="cell-strong">@source.FileName</td>
                                <td class="cell-id">@source.PageNumber</td>
                                <td class="cell-id">@source.ChunkIndex</td>
                                <td class="cell-muted">@uploader</td>
                                <td><span class="source-text">@source.Text</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
