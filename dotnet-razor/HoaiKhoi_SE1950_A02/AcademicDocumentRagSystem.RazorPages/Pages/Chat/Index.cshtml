@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "Chatbot";
    var roleName = ViewContext.HttpContext.Session.GetString(SessionKeys.RoleName);
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Choose a Document</h1>
        <p class="page-subtitle">Select an indexed document to ask questions about its content.</p>
    </div>
    <div class="action-bar">
        @if (roleName == "Teacher")
        {
            <a asp-page="/Documents/Upload" class="btn btn-outline-primary">Upload Document</a>
        }
        <a asp-page="/Chat/Sessions" class="btn btn-secondary">Chat History</a>
    </div>
</div>

@if (Model.Documents.Count == 0)
{
    <div class="empty-state">
        <h3>No indexed documents yet</h3>
        <p>There are no indexed documents available for questions yet.</p>
        @if (roleName == "Teacher")
        {
            <a asp-page="/Documents/Upload" class="btn btn-primary">Upload Document</a>
        }
    </div>
}
else
{
    <div class="table-wrap">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Title</th>
                        <th>Course</th>
                        <th>Chapter</th>
                        <th>File</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var document in Model.Documents)
                    {
                        <tr>
                            <td class="cell-id">@document.DocumentId</td>
                            <td class="cell-strong">@document.Title</td>
                            <td><span class="meta-badge">@document.CourseCode</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(document.Chapter))
                                {
                                    <span class="meta-badge meta-badge--accent">@document.Chapter</span>
                                }
                                else
                                {
                                    <span class="cell-muted">&mdash;</span>
                                }
                            </td>
                            <td class="cell-muted">@document.OriginalFileName</td>
                            <td>
                                <a asp-page="/Chat/Ask" asp-route-documentId="@document.DocumentId" class="btn btn-primary btn-sm">Ask</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
