@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Chat.SessionModel
@{
    ViewData["Title"] = "Chat session";
    var s = Model.Session;
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">@s.Title</h1>
        <p class="page-subtitle">
            <span class="meta-badge">@s.CourseCode</span>
            <span class="cell-muted">@s.DocumentTitle</span>
        </p>
    </div>
    <div class="action-bar">
        <a asp-page="/Chat/Ask" asp-route-documentId="@s.DocumentId" asp-route-chatSessionId="@s.ChatSessionId" class="btn btn-primary">Continue this session</a>
        <a asp-page="/Chat/Sessions" class="btn btn-secondary">Back to history</a>
    </div>
</div>

@if (s.Messages.Count == 0)
{
    <div class="empty-state">
        <h3>No messages in this session</h3>
        <p>This session has no recorded questions yet.</p>
    </div>
}
else
{
    @foreach (var message in s.Messages)
    {
        <div class="surface-card mb-3">
            <div class="chat-question__label">Question · @message.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
            <p class="chat-question__text">@message.Question</p>
            <div class="chat-question__label">Answer</div>
            <div class="chat-answer">@message.Answer</div>
        </div>
    }
}
