@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Chat.SessionsModel
@{
    ViewData["Title"] = "Chat History";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Chat History</h1>
        <p class="page-subtitle">Your previous question-and-answer sessions, grouped by document.</p>
    </div>
    <div class="action-bar">
        <a asp-page="/Chat/Index" class="btn btn-primary">New Question</a>
    </div>
</div>

@if (Model.Sessions.Count == 0)
{
    <div class="empty-state">
        <h3>No chat history yet</h3>
        <p>Ask a question about an indexed document to start your first session.</p>
        <a asp-page="/Chat/Index" class="btn btn-primary">Open Chatbot</a>
    </div>
}
else
{
    <div class="table-wrap">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Document</th>
                        <th>Course</th>
                        <th>Started</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.Sessions)
                    {
                        <tr>
                            <td class="cell-strong">@session.Title</td>
                            <td>@session.DocumentTitle</td>
                            <td><span class="meta-badge">@session.CourseCode</span></td>
                            <td class="cell-muted">@session.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="table-actions">
                                    <a asp-page="/Chat/Session" asp-route-id="@session.ChatSessionId" class="btn btn-secondary btn-sm">Open</a>
                                    <a asp-page="/Chat/Ask" asp-route-documentId="@session.DocumentId" asp-route-chatSessionId="@session.ChatSessionId" class="btn btn-primary btn-sm">Continue</a>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
