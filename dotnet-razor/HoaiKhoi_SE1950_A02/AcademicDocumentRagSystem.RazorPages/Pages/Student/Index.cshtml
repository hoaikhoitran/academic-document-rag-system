@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Student.IndexModel
@{
    ViewData["Title"] = "Student";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Welcome, @Model.FullName</h1>
        <p class="page-subtitle">Student account.</p>
    </div>
</div>

<div class="form-card">
    <h3 class="page-title" style="font-size:1.2rem;">Ask the RAG chatbot</h3>
    <p class="page-subtitle">
        Pick an indexed course document and ask questions about its content. Answers cite the
        passages they were grounded in.
    </p>
    <div class="action-bar">
        <a asp-page="/Chat/Index" class="btn btn-primary">Open Chatbot</a>
        <a asp-page="/Chat/Sessions" class="btn btn-outline-primary">Chat History</a>
    </div>
</div>
