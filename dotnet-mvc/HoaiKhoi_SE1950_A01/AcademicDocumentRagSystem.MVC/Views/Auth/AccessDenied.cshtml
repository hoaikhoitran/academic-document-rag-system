@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = "_LayoutMinimal";
    var role = Context.Session.GetString("RoleName");
}
<div class="text-center py-5">
    <h1 class="font-display fw-bold mb-3">Truy cập bị từ chối</h1>
    <p class="text-muted-edurag mb-4">Bạn không có quyền truy cập trang này.</p>
    @if (role == "Admin")
    {
        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-edurag-warm">Về Dashboard</a>
    }
    else if (role == "Teacher")
    {
        <a asp-controller="Teacher" asp-action="Courses" class="btn btn-edurag-warm">Về Môn học</a>
    }
    else if (role == "Student")
    {
        <a asp-controller="Student" asp-action="Chat" class="btn btn-edurag-warm">Về Hỏi đáp</a>
    }
    else
    {
        <a asp-controller="Auth" asp-action="Login" class="btn btn-edurag-warm">Đăng nhập</a>
    }
</div>
