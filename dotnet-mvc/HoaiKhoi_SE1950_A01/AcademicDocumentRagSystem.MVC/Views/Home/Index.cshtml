@{
    ViewData["Title"] = "Home Page";
    var isLoggedIn = Context.Session.GetString("Email") != null;
}

<section class="landing-hero">
    <span class="landing-eyebrow">Academic Document RAG</span>
    <h1>Ask questions and get answers grounded in your course documents.</h1>
    <p class="landing-lead">
        Organize courses, upload and index academic documents, then chat with a
        retrieval-augmented assistant that answers using your material and cites the
        exact sources it relied on.
    </p>

    <div class="action-bar">
        @if (isLoggedIn)
        {
            <a asp-controller="Courses" asp-action="Index" class="btn btn-primary">Go to Courses</a>
            <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-primary">Open Chatbot</a>
        }
        else
        {
            <a asp-controller="Auth" asp-action="Login" class="btn btn-primary">Sign in to get started</a>
        }
    </div>

    <div class="flow-steps">
        <span class="flow-step"><span class="flow-step__num">1</span> Manage courses</span>
        <span class="flow-arrow">&rarr;</span>
        <span class="flow-step"><span class="flow-step__num">2</span> Upload document</span>
        <span class="flow-arrow">&rarr;</span>
        <span class="flow-step"><span class="flow-step__num">3</span> Index document</span>
        <span class="flow-arrow">&rarr;</span>
        <span class="flow-step"><span class="flow-step__num">4</span> Ask questions</span>
        <span class="flow-arrow">&rarr;</span>
        <span class="flow-step"><span class="flow-step__num">5</span> Grounded answer &amp; sources</span>
    </div>
</section>

<div class="row g-4 mt-1">
    <div class="col-md-6 col-lg-3">
        <div class="feature-card">
            <span class="feature-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
            </span>
            <h3>Course Management</h3>
            <p>Create and maintain courses with codes, descriptions, and active status to keep your material organized.</p>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="feature-card">
            <span class="feature-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <path d="M17 8l-5-5-5 5" />
                    <path d="M12 3v12" />
                </svg>
            </span>
            <h3>Document Upload &amp; Indexing</h3>
            <p>Upload documents to a course and index them so their content becomes searchable for question answering.</p>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="feature-card">
            <span class="feature-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z" />
                </svg>
            </span>
            <h3>RAG Chatbot</h3>
            <p>Pick an indexed document and ask questions in plain language. The assistant retrieves relevant passages to answer.</p>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="feature-card">
            <span class="feature-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 11l3 3L22 4" />
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                </svg>
            </span>
            <h3>Source-grounded Answers</h3>
            <p>Every answer comes with the source passages it used &mdash; file, page, and chunk &mdash; so you can verify it.</p>
        </div>
    </div>
</div>
