@model List<AcademicDocumentRagSystem.Services.DTOs.Chat.ChatSessionDto>
@{
    ViewData["Title"] = "Chat History";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Chat History</h1>
        <p class="page-subtitle">Review previous question-answer sessions and continue asking in the same context.</p>
    </div>
    <div class="action-bar">
        <a asp-action="Index" class="btn btn-primary">Choose Document</a>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="empty-state">
        <h3>No chat sessions yet</h3>
        <p>Choose an indexed document and ask your first question to create a session.</p>
        <a asp-action="Index" class="btn btn-primary">Choose Document</a>
    </div>
}
else
{
    <div class="table-wrap">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Document</th>
                        <th>Course</th>
                        <th>Last activity</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model)
                    {
                        <tr>
                            <td class="cell-strong">@session.Title</td>
                            <td>@session.DocumentTitle</td>
                            <td><span class="meta-badge">@session.CourseCode</span></td>
                            <td class="cell-muted">@((session.UpdatedAt ?? session.CreatedAt).ToLocalTime().ToString("g"))</td>
                            <td>
                                <span class="table-actions">
                                    <a asp-action="Session" asp-route-id="@session.ChatSessionId" class="btn btn-primary btn-sm">Open</a>
                                    <a asp-action="Ask" asp-route-documentId="@session.DocumentId" asp-route-chatSessionId="@session.ChatSessionId" class="btn btn-secondary btn-sm">Continue</a>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
