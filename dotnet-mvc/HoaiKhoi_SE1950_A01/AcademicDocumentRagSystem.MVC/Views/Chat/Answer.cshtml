@model AcademicDocumentRagSystem.Services.DTOs.Chat.ChatAnswerDto
@{
    ViewData["Title"] = "Answer";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Chatbot Answer</h1>
        <p class="page-subtitle">A retrieval-augmented answer based on the selected document, with its sources.</p>
    </div>
</div>

<div class="surface-card mb-3">
    <div class="chat-question__label">Your question</div>
    <p class="chat-question__text">@Model.Question</p>
</div>

<div class="surface-card mb-4">
    <div class="chat-question__label">Answer</div>
    <div class="chat-answer">@Model.Answer</div>
</div>

<h2 class="page-title" style="font-size:1.2rem; margin-bottom:1rem;">Sources</h2>

@if (Model.Sources == null || !Model.Sources.Any())
{
    <div class="empty-state">
        <span class="empty-state__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <path d="M14 2v6h6" />
            </svg>
        </span>
        <h3>No sources returned</h3>
        <p>This answer did not reference any specific passages from the document.</p>
    </div>
}
else
{
    <div class="table-wrap mb-4">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>File</th>
                        <th>Page</th>
                        <th>Chunk</th>
                        <th>Text</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var source in Model.Sources)
                    {
                        <tr>
                            <td class="cell-strong">@source.FileName</td>
                            <td class="cell-id">@source.PageNumber</td>
                            <td class="cell-id">@source.ChunkIndex</td>
                            <td><span class="source-text">@source.Text</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="action-bar">
    <a asp-action="Ask" asp-route-documentId="@Model.DocumentId" asp-route-chatSessionId="@Model.ChatSessionId" class="btn btn-primary">Continue This Session</a>
    <a asp-action="Session" asp-route-id="@Model.ChatSessionId" class="btn btn-secondary">View Session</a>
    <a asp-action="Index" class="btn btn-secondary">Back to Documents</a>
</div>
