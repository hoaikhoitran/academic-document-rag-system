@model AcademicDocumentRagSystem.Services.DTOs.Chat.AskQuestionDto
@{
    ViewData["Title"] = "Ask a Question";
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Ask a Question</h1>
        <p class="page-subtitle">Ask anything about the selected document. The answer will cite the sources it used.</p>
        <span class="context-chip mt-2"><span>Document</span> #@Model.DocumentId</span>
        @if (Model.ChatSessionId.HasValue)
        {
            <span class="context-chip mt-2"><span>Session</span> #@Model.ChatSessionId</span>
        }
    </div>
</div>

<div class="form-card" style="max-width:760px;">
    <form asp-action="Ask" method="post">
        <div asp-validation-summary="All" class="text-danger"></div>

        <input type="hidden" asp-for="DocumentId" />
        <input type="hidden" asp-for="ChatSessionId" />

        <div class="form-field">
            <label asp-for="Question" class="form-label">Your question</label>
            <textarea asp-for="Question" class="form-control" rows="4"
                      placeholder="e.g. Summarize the key concepts in this chapter."></textarea>
            <span asp-validation-for="Question" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Ask</button>
            @if (Model.ChatSessionId.HasValue)
            {
                <a asp-action="Session" asp-route-id="@Model.ChatSessionId" class="btn btn-secondary">Back to Session</a>
            }
            else
            {
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            }
        </div>
    </form>
</div>
