@model AcademicDocumentRagSystem.Services.DTOs.Chat.ChatWorkspaceDto
@using AcademicDocumentRagSystem.MVC.ViewModels.Mock
@{
    ViewData["Title"] = "Hỏi đáp";
    Layout = "_LayoutStudent";
    var sidebarDocs = Model.ActiveDocument != null
        ? Model.Documents.Where(d => d.CourseCode == Model.ActiveDocument.CourseCode).Take(8).ToList()
        : Model.Documents.Take(8).ToList();
}
<div class="chat-grid">
    <div class="chat-main">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success m-3 mb-0 py-2 small">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3 mb-0 py-2 small">@Model.ErrorMessage</div>
        }
        @if (Model.ActiveDocument == null && Model.Documents.Any())
        {
            <div class="chat-main__messages">
                <div class="chat-main__thread">
                    <div class="text-center pt-5 pb-4">
                        <div class="chat-avatar mx-auto mb-3" style="width:3rem;height:3rem;">
                            @{ ViewData["Icon"] = "sparkles"; ViewData["IconSize"] = "22"; }
                            @await Html.PartialAsync("_Icons")
                        </div>
                        <h2 class="font-display fw-bold fs-4 mb-1">Bắt đầu hỏi đáp</h2>
                        <p class="small text-muted-edurag">Chọn một tài liệu để trợ lý trả lời dựa trên nội dung đã index.</p>
                    </div>
                    <div class="row g-2">
                        @foreach (var d in Model.Documents)
                        {
                            <div class="col-md-6">
                                <a asp-action="Chat" asp-route-documentId="@d.DocumentId" class="edurag-card p-3 d-block text-decoration-none text-dark file-card">
                                    <div class="fw-semibold small">@d.Title</div>
                                    <div class="small text-muted-edurag">@d.CourseCode · @d.Chapter</div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (Model.ActiveDocument != null)
        {
            <div class="chat-main__header">
                <div class="flex-grow-1 min-width-0">
                    <div class="font-display fw-bold text-truncate">@(Model.ActiveSession?.Title ?? Model.ActiveDocument.Title)</div>
                    <div class="small text-muted-edurag">Môn @Model.ActiveDocument.CourseCode · @Model.ActiveDocument.OriginalFileName</div>
                </div>
                <a asp-action="NewChat" asp-route-documentId="@Model.ActiveDocument.DocumentId" class="btn btn-sm btn-edurag-outline">+ Mới</a>
            </div>
            <div class="chat-main__messages">
                <div class="chat-main__thread">
                    @if (Model.ActiveSession?.Messages.Any() == true)
                    {
                        @foreach (var m in Model.ActiveSession.Messages)
                        {
                            <div class="d-flex justify-content-end mb-3">
                                <div class="chat-bubble-user">@m.Question</div>
                            </div>
                            <div class="d-flex gap-3 mb-4">
                                <div class="chat-avatar">
                                    @{ ViewData["Icon"] = "sparkles"; ViewData["IconSize"] = "16"; }
                                    @await Html.PartialAsync("_Icons")
                                </div>
                                <div class="min-width-0">
                                    <div class="chat-bubble-assistant">@Html.Raw(MockDataProvider.FormatBoldMarkdown(m.Answer))</div>
                                    @if (m.Sources.Any())
                                    {
                                        <div class="d-flex flex-wrap gap-1 mt-2">
                                            @foreach (var cit in m.Sources)
                                            {
                                                <span class="citation-chip">
                                                    @{ ViewData["Icon"] = "quote"; ViewData["IconSize"] = "12"; }
                                                    @await Html.PartialAsync("_Icons")
                                                    @cit.FileName @(cit.PageNumber.HasValue ? $"· tr.{cit.PageNumber}" : "")
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted-edurag text-center py-5">Đặt câu hỏi đầu tiên về tài liệu này.</p>
                    }
                </div>
            </div>
            <div class="chat-main__inputbar">
                <form asp-action="Ask" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DocumentId" value="@Model.AskForm.DocumentId" />
                    <input type="hidden" name="ChatSessionId" value="@Model.AskForm.ChatSessionId" />
                    <div class="chat-input-card">
                        <input type="text" name="Question" placeholder="Hỏi về tài liệu môn @Model.ActiveDocument.CourseCode..." required autocomplete="off" />
                        <button type="submit" class="btn btn-edurag-warm rounded-3 d-inline-flex align-items-center justify-content-center" style="width:42px;height:42px;padding:0;">
                            @{ ViewData["Icon"] = "send"; ViewData["IconSize"] = "16"; }
                            @await Html.PartialAsync("_Icons")
                        </button>
                    </div>
                </form>
                <p class="text-center mb-0 mt-2" style="font-size:11px;color:var(--edurag-muted);">Trả lời được giới hạn trong phạm vi tài liệu giảng viên đã upload.</p>
            </div>
        }
        else
        {
            <div class="p-5 text-center text-muted-edurag my-auto">
                <p>Chưa có tài liệu đã index. Vui lòng liên hệ giảng viên.</p>
                <a asp-action="Library" class="btn btn-edurag-warm">Thư viện tài liệu</a>
            </div>
        }
    </div>
    <aside class="chat-sources">
        <div class="small fw-semibold text-muted-edurag text-uppercase mb-1" style="letter-spacing:.06em;">Nguồn dữ liệu</div>
        @if (Model.ActiveDocument != null)
        {
            <div class="font-display fw-bold mb-0">Môn @Model.ActiveDocument.CourseCode</div>
            <div class="small text-muted-edurag mb-3">@sidebarDocs.Count tài liệu khả dụng</div>
        }
        else
        {
            <div class="small text-muted-edurag mb-3">Chọn tài liệu để bắt đầu</div>
        }
        @foreach (var d in sidebarDocs)
        {
            <a asp-action="Chat" asp-route-documentId="@d.DocumentId"
               class="source-doc-card @(Model.SelectedDocumentId == d.DocumentId ? "active" : "")">
                <div class="fw-semibold text-truncate">@d.Title</div>
                <div class="text-muted-edurag">@d.CourseCode · @d.Chapter</div>
            </a>
        }
    </aside>
</div>
