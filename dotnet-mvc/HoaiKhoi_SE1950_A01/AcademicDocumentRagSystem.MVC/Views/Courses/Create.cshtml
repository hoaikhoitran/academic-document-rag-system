@model AcademicDocumentRagSystem.Services.DTOs.Courses.CreateCourseDto
@{
    ViewData["Title"] = "Thêm môn học";
    Layout = "_LayoutDashboard";
}

<div class="p-4 p-md-5">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-edurag-ghost mb-3">← Quay lại</a>
        <h1 class="font-display fs-2 fw-bold mb-1">Thêm môn học</h1>
        <p class="text-muted-edurag mb-0">Thêm môn học mới để upload và index tài liệu.</p>
    </div>

    <div class="edurag-card p-4 p-md-5" style="max-width:680px;">
        <form asp-action="Create" method="post" class="vstack gap-3">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div>
                <label asp-for="Code" class="form-label fw-semibold">Mã môn</label>
                <input asp-for="Code" class="form-control" placeholder="VD: PRN222" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Name" class="form-label fw-semibold">Tên môn</label>
                <input asp-for="Name" class="form-control" placeholder="VD: Programming with .NET" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn về môn học"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="form-check">
                <input asp-for="Status" type="checkbox" class="form-check-input" />
                <label asp-for="Status" class="form-check-label">Môn học đang hoạt động</label>
            </div>

            <div class="d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-edurag-warm">Lưu</button>
                <a asp-action="Index" class="btn btn-edurag-outline">Huỷ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
