@model List<AcademicDocumentRagSystem.Services.DTOs.Courses.CourseDto>

<h2>Course Management</h2>

<a asp-action="Create" class="btn btn-primary">Create Course</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Description</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Code</td>
                <td>@course.Name</td>
                <td>@course.Description</td>
                <td>@(course.Status ? "Active" : "Inactive")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@course.CourseId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@course.CourseId"
                       onclick="return confirm('Are you sure you want to delete this course?')">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>