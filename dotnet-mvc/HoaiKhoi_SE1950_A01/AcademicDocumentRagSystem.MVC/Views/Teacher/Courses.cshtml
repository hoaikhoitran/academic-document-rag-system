@model List<AcademicDocumentRagSystem.MVC.ViewModels.TeacherCourseCardViewModel>
@{
    ViewData["Title"] = "Môn học";
    Layout = "_LayoutDashboard";
}
<div class="p-4 p-md-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
            <h1 class="font-display fs-2 fw-bold mb-1">Môn học</h1>
            <p class="text-muted-edurag mb-0">
                Các môn được phân công cho bạn
                <span id="live-indicator" class="live-indicator ms-1">live</span>
            </p>
        </div>
        <a asp-action="Upload" class="btn btn-edurag-warm btn-sm d-inline-flex align-items-center gap-1">
            @{ ViewData["Icon"] = "upload"; ViewData["IconSize"] = "14"; }
            @await Html.PartialAsync("_Icons")
            Upload tài liệu
        </a>
    </div>
    <div id="course-list" data-refresh-url="@Url.Action("CoursesTable", "Teacher")">
        @await Html.PartialAsync("_CourseCards", Model)
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js" crossorigin="anonymous"></script>
    <script src="~/js/course-realtime.js" asp-append-version="true"></script>
}
