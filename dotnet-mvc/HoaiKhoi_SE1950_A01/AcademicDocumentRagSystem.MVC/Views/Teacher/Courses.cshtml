@model List<AcademicDocumentRagSystem.MVC.ViewModels.TeacherCourseCardViewModel>
@{
    ViewData["Title"] = "Môn học";
    Layout = "_LayoutDashboard";
}
<div class="p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="font-display fs-2 fw-bold mb-1">Môn học</h1>
            <p class="text-muted-edurag mb-0">Môn được gán cho giảng viên</p>
        </div>
        <a asp-action="Upload" class="btn btn-edurag-warm btn-sm">Upload tài liệu</a>
    </div>
    <div class="row g-4">
        @foreach (var card in Model)
        {
            <div class="col-md-6 col-lg-4">
                <a asp-action="Upload" class="edurag-card p-4 d-block text-decoration-none text-dark feature-card h-100">
                    <span class="badge bg-light text-dark mb-2">@card.Course.Code</span>
                    <h3 class="font-display fw-bold fs-5 mb-2">@card.Course.Name</h3>
                    <p class="small text-muted-edurag mb-0">@card.DocumentCount tài liệu · @card.IndexedCount indexed · @card.TotalChunks chunks</p>
                </a>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12"><div class="edurag-card p-5 text-center text-muted-edurag">Chưa được gán môn học. Liên hệ Admin.</div></div>
        }
    </div>
</div>
