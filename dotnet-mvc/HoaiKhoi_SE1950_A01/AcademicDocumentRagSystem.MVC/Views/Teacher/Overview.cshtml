@model AcademicDocumentRagSystem.MVC.ViewModels.Mock.AdminDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
    Layout = "_LayoutDashboard";
}
<div class="p-4 p-md-5">
    <h1 class="font-display fs-2 fw-bold mb-1">Tổng quan giảng dạy</h1>
    <p class="text-muted-edurag mb-4">Mock data · demo UI</p>
    <div class="row g-3 mb-4">
        @foreach (var s in new[] { ("24", "Tài liệu"), ("21", "Indexed"), ("1,840", "Chunks"), ("48", "Phiên chat") })
        {
            <div class="col-md-3">
                <div class="edurag-card p-4">
                    <div class="font-display fs-4 fw-bold">@s.Item1</div>
                    <div class="small text-muted-edurag">@s.Item2</div>
                </div>
            </div>
        }
    </div>
    <div class="edurag-card p-4">
        <h2 class="font-display fw-bold fs-6 mb-3">Hoạt động hỏi đáp (7 ngày)</h2>
        <div class="chart-bars">
            @foreach (var u in Model.UsageData)
            {
                var h = Model.MaxQueries > 0 ? (int)(u.Queries * 100.0 / Model.MaxQueries) : 4;
                <div class="chart-bar-col">
                    <div class="chart-bar-fill" style="height:@(Math.Max(h, 8))%;"></div>
                    <span class="small text-muted-edurag">@u.Day</span>
                    <span class="small fw-semibold">@u.Queries</span>
                </div>
            }
        </div>
    </div>
</div>
