@model AcademicDocumentRagSystem.Services.DTOs.Documents.DocumentUploadDto
@{
    ViewData["Title"] = "Upload tài liệu";
    Layout = "_LayoutDashboard";
}
<div class="p-4 p-md-5">
    <h1 class="font-display fs-2 fw-bold mb-1">Upload tài liệu</h1>
    <p class="text-muted-edurag mb-4">PDF, DOCX, PPTX, TXT — tự động chunk và index RAG</p>
    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
    <div class="edurag-card p-4 p-md-5">
        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="CourseId" class="form-label">Môn học</label>
                <select asp-for="CourseId" class="form-select">
                    @foreach (var c in Model.AvailableCourses)
                    {
                        <option value="@c.CourseId">@c.Code — @c.Name</option>
                    }
                </select>
                <span asp-validation-for="CourseId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label">Tiêu đề</label>
                <input asp-for="Title" class="form-control" placeholder="VD: Chương 1 - Giới thiệu" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="File" class="form-label">File</label>
                <input asp-for="File" type="file" class="form-control" accept=".pdf,.docx,.pptx,.txt" />
                <span asp-validation-for="File" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Chapter" class="form-label">Chương</label>
                <input asp-for="Chapter" class="form-control" placeholder="Chương 1" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Mô tả (tùy chọn)</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-edurag-warm">Upload và Index</button>
            <a asp-action="IndexStatus" class="btn btn-outline-secondary ms-2">Trạng thái index</a>
        </form>
    </div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
