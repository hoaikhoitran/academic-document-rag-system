@model AcademicDocumentRagSystem.MVC.ViewModels.Mock.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_LayoutDashboard";
}
<div class="p-4 p-md-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
            <h1 class="font-display fs-2 fw-bold mb-1">Bảng điều khiển</h1>
            <p class="text-muted-edurag mb-0">Mock data · demo UI</p>
        </div>
        <div class="d-flex gap-2">
            <span class="pill-filter">7 ngày</span>
            <span class="pill-filter active">30 ngày</span>
            <span class="pill-filter">90 ngày</span>
        </div>
    </div>
    <div class="row g-3 mb-4">
        @foreach (var s in new[] {
            ("1,284", "Người dùng hoạt động", "+12.4%", "users"),
            ("3,402", "Câu hỏi / ngày", "+8.2%", "message"),
            ("847", "Tài liệu đã index", "+3.1%", "file"),
            ("0.89", "RAGAS faithfulness", "+0.04", "trending-up") })
        {
            <div class="col-md-3 col-6">
                <div class="edurag-card p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="stat-icon-box bg-gradient-warm text-white shadow-glow">
                            @{ ViewData["Icon"] = s.Item4; ViewData["IconSize"] = "18"; }
                            @await Html.PartialAsync("_Icons")
                        </span>
                        <span class="kpi-delta">
                            @{ ViewData["Icon"] = "arrow-up"; ViewData["IconSize"] = "11"; }
                            @await Html.PartialAsync("_Icons")
                            @s.Item3
                        </span>
                    </div>
                    <div class="font-display fs-3 fw-bold lh-1">@s.Item1</div>
                    <div class="small text-muted-edurag mt-1">@s.Item2</div>
                </div>
            </div>
        }
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="edurag-card p-4">
                <h3 class="font-display fw-bold fs-6 mb-3">Lưu lượng truy vấn</h3>
                <div class="chart-bars" style="height:240px;">
                    @foreach (var u in Model.UsageData)
                    {
                        var qh = Model.MaxQueries > 0 ? (int)(u.Queries * 85.0 / Model.MaxQueries) : 4;
                        var uh = Model.MaxUsers > 0 ? (int)(u.Users * 70.0 / Model.MaxUsers) : 4;
                        <div class="chart-bar-col">
                            <div class="d-flex gap-1 align-items-end w-100 justify-content-center" style="height:180px;">
                                <div class="chart-bar-fill" style="height:@(Math.Max(qh, 6))%;width:18px;"></div>
                                <div class="chart-bar-fill secondary" style="height:@(Math.Max(uh, 4))%;width:18px;"></div>
                            </div>
                            <span class="small text-muted-edurag">@u.Day</span>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="edurag-card p-4 mb-3">
                <h3 class="font-display fw-bold fs-6 mb-3">Phân bổ theo môn</h3>
                @foreach (var c in Model.Courses)
                {
                    <div class="d-flex justify-content-between small mb-2">
                        <span class="fw-semibold">@c.Code</span>
                        <span class="text-muted-edurag">@c.Students SV</span>
                    </div>
                }
            </div>
            <div class="edurag-card p-4">
                <h3 class="font-display fw-bold fs-6 mb-2">Hoạt động gần đây</h3>
                <ul class="list-unstyled small text-muted-edurag mb-0">
                    <li class="mb-2">SV hỏi AI101 — 2 phút trước</li>
                    <li class="mb-2">GV upload PDF — 15 phút trước</li>
                    <li>Index hoàn tất — 1 giờ trước</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="mt-3">
        <a asp-action="Users" class="btn btn-outline-secondary btn-sm me-2">Quản lý người dùng</a>
        <a asp-controller="Accounts" asp-action="Index" class="btn btn-outline-secondary btn-sm">Accounts (CRUD)</a>
    </div>
</div>
