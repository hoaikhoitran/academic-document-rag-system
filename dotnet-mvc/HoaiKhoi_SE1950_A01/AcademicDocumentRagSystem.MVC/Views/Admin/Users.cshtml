@model List<AcademicDocumentRagSystem.Services.DTOs.Accounts.AccountListItemDto>
@{
    ViewData["Title"] = "Người dùng";
    Layout = "_LayoutDashboard";
    var searchTerm = ViewBag.SearchTerm as string;
    var roleFilter = ViewBag.Role as int?;
}
<div class="p-4 p-md-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
            <h1 class="font-display fs-2 fw-bold mb-1">Người dùng</h1>
            <p class="text-muted-edurag mb-0">Quản lý tài khoản trong hệ thống</p>
        </div>
        <a asp-controller="Accounts" asp-action="Create" class="btn btn-edurag-warm btn-sm d-inline-flex align-items-center gap-1">
            @{ ViewData["Icon"] = "plus"; ViewData["IconSize"] = "14"; }
            @await Html.PartialAsync("_Icons")
            Thêm người dùng
        </a>
    </div>
    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-action="Users" asp-route-searchTerm="@searchTerm" class="pill-filter @(roleFilter == null ? "active" : "")">Tất cả</a>
        <a asp-action="Users" asp-route-role="1" asp-route-searchTerm="@searchTerm" class="pill-filter @(roleFilter == 1 ? "active" : "")">Student</a>
        <a asp-action="Users" asp-route-role="2" asp-route-searchTerm="@searchTerm" class="pill-filter @(roleFilter == 2 ? "active" : "")">Teacher</a>
    </div>
    <div class="edurag-card overflow-hidden">
        <div class="p-3 border-bottom">
            <form asp-action="Users" method="get" class="d-flex gap-2">
                @if (roleFilter.HasValue)
                {
                    <input type="hidden" name="role" value="@roleFilter" />
                }
                <input type="search" name="searchTerm" value="@searchTerm" class="form-control form-control-sm" style="max-width:280px;" placeholder="Tìm tên, email..." />
                <button type="submit" class="btn btn-sm btn-edurag-outline d-inline-flex align-items-center gap-1">
                    @{ ViewData["Icon"] = "search"; ViewData["IconSize"] = "14"; }
                    @await Html.PartialAsync("_Icons")
                    Tìm
                </button>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table-edurag">
                <thead>
                    <tr><th>Người dùng</th><th>Vai trò</th><th>Môn học</th><th>Trạng thái</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var badge = u.RoleName == "Student" ? "role-badge-student" : u.RoleName == "Teacher" ? "role-badge-teacher" : "role-badge-admin";
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="avatar-initial" style="width:36px;height:36px;font-size:14px;">@(u.FullName.Length > 0 ? u.FullName[0] : '?')</span>
                                    <div>
                                        <div class="fw-semibold">@u.FullName</div>
                                        <div class="small text-muted-edurag">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="@badge">@u.RoleName</span></td>
                            <td class="small">@(u.CourseCode ?? "—")</td>
                            <td><span class="@(u.Status ? "status-badge-indexed" : "status-badge-failed")">@(u.Status ? "Hoạt động" : "Đã khoá")</span></td>
                            <td class="text-end">
                                <a asp-controller="Accounts" asp-action="Edit" asp-route-id="@u.AccountId" class="btn btn-sm btn-edurag-ghost">Sửa</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted-edurag py-4">Không tìm thấy người dùng.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
