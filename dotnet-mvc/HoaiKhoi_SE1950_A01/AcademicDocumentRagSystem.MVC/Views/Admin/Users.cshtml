@model List<AcademicDocumentRagSystem.Services.DTOs.Accounts.AccountListItemDto>
@{
    ViewData["Title"] = "Người dùng";
    Layout = "_LayoutDashboard";
    var searchTerm = ViewBag.SearchTerm as string;
    var roleFilter = ViewBag.Role as int?;
}
<div class="p-4 p-md-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
            <h1 class="font-display fs-2 fw-bold mb-1">Người dùng</h1>
            <p class="text-muted-edurag mb-0">Dữ liệu từ Accounts service</p>
        </div>
        <a asp-controller="Accounts" asp-action="Create" class="btn btn-edurag-warm">+ Thêm người dùng</a>
    </div>
    <div class="edurag-card overflow-hidden">
        <div class="p-3 border-bottom">
            <form asp-action="Users" method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <input type="search" name="searchTerm" value="@searchTerm" class="form-control form-control-sm" placeholder="Tìm tên, email..." />
                </div>
                <div class="col-md-3">
                    <select name="role" class="form-select form-select-sm">
                        <option value="">Tất cả vai trò</option>
                        @if (roleFilter == 1)
                        {
                            <option value="1" selected="selected">Student</option>
                        }
                        else
                        {
                            <option value="1">Student</option>
                        }
                        @if (roleFilter == 2)
                        {
                            <option value="2" selected="selected">Teacher</option>
                        }
                        else
                        {
                            <option value="2">Teacher</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-sm btn-edurag-warm w-100">Lọc</button>
                </div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light small text-uppercase text-muted-edurag">
                    <tr><th>Người dùng</th><th>Vai trò</th><th>Môn học</th><th>Trạng thái</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var badge = u.RoleName == "Student" ? "role-badge-student" : u.RoleName == "Teacher" ? "role-badge-teacher" : "role-badge-admin";
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="rounded-circle bg-gradient-warm text-white d-inline-flex align-items-center justify-content-center fw-semibold" style="width:36px;height:36px;">@(u.FullName.Length > 0 ? u.FullName[0] : '?')</span>
                                    <div>
                                        <div class="fw-semibold">@u.FullName</div>
                                        <div class="small text-muted-edurag">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge @badge">@u.RoleName</span></td>
                            <td class="small">@(u.CourseCode ?? "—")</td>
                            <td><span class="badge @(u.Status ? "status-badge-indexed" : "bg-secondary")">@(u.Status ? "Active" : "Inactive")</span></td>
                            <td class="text-end">
                                <a asp-controller="Accounts" asp-action="Edit" asp-route-id="@u.AccountId" class="btn btn-sm btn-outline-secondary">Sửa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
