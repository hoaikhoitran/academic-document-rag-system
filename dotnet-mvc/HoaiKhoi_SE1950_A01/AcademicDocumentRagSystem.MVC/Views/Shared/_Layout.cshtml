<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Academic Document RAG</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AcademicDocumentRagSystem.MVC.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="app-navbar navbar navbar-expand-md">
            <div class="container-fluid app-shell" style="padding-top:.6rem;padding-bottom:.6rem;">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 4a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z" />
                            <path d="M14 2v6h6" />
                            <path d="M9 13h6M9 17h4" />
                        </svg>
                    </span>
                    Academic Document RAG
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-md-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (Context.Session.GetString("Email") != null)
                        {
                            var roleName = Context.Session.GetString("RoleName");

                            if (roleName == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Accounts" asp-action="Index">Accounts</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Documents" asp-action="All">Documents</a>
                                </li>
                            }

                            if (roleName == "Teacher")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Documents" asp-action="Upload">Upload Document</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Documents" asp-action="Index">My Documents</a>
                                </li>
                            }

                            if (roleName == "Student" || roleName == "Teacher")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Chat" asp-action="Index">Chatbot</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Chat" asp-action="Sessions">Chat History</a>
                                </li>
                            }
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-md-center gap-md-2">
                        @if (Context.Session.GetString("Email") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-user">
                                    <span class="nav-user__name">@Context.Session.GetString("FullName")</span>
                                    <span class="nav-user__role">@Context.Session.GetString("RoleName")</span>
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm" asp-controller="Auth" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="app-main">
        <div class="app-shell">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="app-shell d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>&copy; 2026 Academic Document RAG System</span>
            <span>Retrieval-augmented answers grounded in your course documents.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
