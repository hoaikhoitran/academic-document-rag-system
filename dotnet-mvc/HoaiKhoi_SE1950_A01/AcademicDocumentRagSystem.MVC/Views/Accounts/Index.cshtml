@model List<AcademicDocumentRagSystem.Services.DTOs.Accounts.AccountListItemDto>
@{
    ViewData["Title"] = "Accounts";
    string? searchTerm = ViewBag.SearchTerm as string;
    int? selectedRole = ViewBag.Role as int?;
    bool? selectedStatus = ViewBag.Status as bool?;
}

<div class="page-header">
    <div class="page-header__text">
        <h1 class="page-title">Account Management</h1>
        <p class="page-subtitle">Create, update, filter, and deactivate student and teacher accounts.</p>
    </div>
    <div class="action-bar">
        <a asp-action="Create" class="btn btn-primary">Create Account</a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="form-card mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label" for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Email or full name" />
        </div>

        <div class="col-md-3">
            <label class="form-label" for="role">Role</label>
            <select id="role" name="role" class="form-control">
                <option value="">All roles</option>
                <option value="1" selected="@(selectedRole == 1 ? "selected" : null)">Student</option>
                <option value="2" selected="@(selectedRole == 2 ? "selected" : null)">Teacher</option>
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label" for="status">Status</label>
            <select id="status" name="status" class="form-control">
                <option value="">All</option>
                <option value="true" selected="@(selectedStatus == true ? "selected" : null)">Active</option>
                <option value="false" selected="@(selectedStatus == false ? "selected" : null)">Inactive</option>
            </select>
        </div>

        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>
</div>

@if (Model == null || !Model.Any())
{
    <div class="empty-state">
        <h3>No accounts found</h3>
        <p>Create an account or adjust the search filters.</p>
        <a asp-action="Create" class="btn btn-primary">Create Account</a>
    </div>
}
else
{
    <div class="table-wrap">
        <div class="table-responsive-wrap">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Full name</th>
                        <th>Role</th>
                        <th>Course</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in Model)
                    {
                        <tr>
                            <td class="cell-strong">@account.Email</td>
                            <td>@account.FullName</td>
                            <td><span class="meta-badge">@account.RoleName</span></td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(account.CourseCode))
                                {
                                    <span class="meta-badge meta-badge--accent">@account.CourseCode</span>
                                }
                                else
                                {
                                    <span class="cell-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (account.Status)
                                {
                                    <span class="status-badge status-badge--active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-badge--inactive">Inactive</span>
                                }
                            </td>
                            <td>
                                <span class="table-actions">
                                    <a asp-action="Edit" asp-route-id="@account.AccountId" class="btn btn-secondary btn-sm">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@account.AccountId" method="post" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this account?')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                    </form>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
