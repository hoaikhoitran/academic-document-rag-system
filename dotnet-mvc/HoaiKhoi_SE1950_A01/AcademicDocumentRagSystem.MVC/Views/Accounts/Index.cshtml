@model List<AcademicDocumentRagSystem.Services.DTOs.Accounts.AccountListItemDto>
@{
    ViewData["Title"] = "Người dùng";
    Layout = "_LayoutDashboard";
    string? searchTerm = ViewBag.SearchTerm as string;
    int? selectedRole = ViewBag.Role as int?;
    bool? selectedStatus = ViewBag.Status as bool?;
}

<div class="p-4 p-md-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
            <h1 class="font-display fs-2 fw-bold mb-1">Quản lý tài khoản</h1>
            <p class="text-muted-edurag mb-0">Tạo, cập nhật, lọc và quản lý tài khoản sinh viên, giảng viên</p>
        </div>
        <a asp-action="Create" class="btn btn-edurag-warm btn-sm d-inline-flex align-items-center gap-1">
            @{ ViewData["Icon"] = "plus"; ViewData["IconSize"] = "14"; }
            @await Html.PartialAsync("_Icons")
            Thêm tài khoản
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-3">@TempData["Error"]</div>
    }

    <div class="edurag-card p-3 mb-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-semibold" for="searchTerm">Tìm kiếm</label>
                <input id="searchTerm" name="searchTerm" value="@searchTerm" class="form-control form-control-sm" placeholder="Email hoặc họ tên" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold" for="role">Vai trò</label>
                <select id="role" name="role" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @if (selectedRole == 1) { <option value="1" selected>Student</option> } else { <option value="1">Student</option> }
                    @if (selectedRole == 2) { <option value="2" selected>Teacher</option> } else { <option value="2">Teacher</option> }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold" for="status">Trạng thái</label>
                <select id="status" name="status" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @if (selectedStatus == true) { <option value="true" selected>Hoạt động</option> } else { <option value="true">Hoạt động</option> }
                    @if (selectedStatus == false) { <option value="false" selected>Đã khoá</option> } else { <option value="false">Đã khoá</option> }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-edurag-outline">Lọc</button>
                <a asp-action="Index" class="btn btn-sm btn-edurag-ghost">Đặt lại</a>
            </div>
        </form>
    </div>

    <div class="edurag-card overflow-hidden">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center text-muted-edurag py-5">
                <p class="mb-3">Không tìm thấy tài khoản.</p>
                <a asp-action="Create" class="btn btn-sm btn-edurag-warm">Thêm tài khoản</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-edurag">
                    <thead>
                        <tr>
                            <th>Người dùng</th>
                            <th>Vai trò</th>
                            <th>Môn học</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in Model)
                        {
                            var badge = account.RoleName == "Student" ? "role-badge-student" : "role-badge-teacher";
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="avatar-initial" style="width:36px;height:36px;font-size:14px;">@(account.FullName.Length > 0 ? account.FullName[0] : '?')</span>
                                        <div>
                                            <div class="fw-semibold">@account.FullName</div>
                                            <div class="small text-muted-edurag">@account.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="@badge">@account.RoleName</span></td>
                                <td class="small">@(string.IsNullOrWhiteSpace(account.CourseCode) ? "—" : account.CourseCode)</td>
                                <td>
                                    <span class="@(account.Status ? "status-badge-indexed" : "status-badge-failed")">
                                        @(account.Status ? "Hoạt động" : "Đã khoá")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@account.AccountId" class="btn btn-sm btn-edurag-ghost">Sửa</a>
                                        <form asp-action="Delete" asp-route-id="@account.AccountId" method="post" class="d-inline"
                                              onsubmit="return confirm('Bạn có chắc muốn xóa tài khoản này?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
