@model AcademicDocumentRagSystem.Services.DTOs.Accounts.UpdateAccountDto
@{
    ViewData["Title"] = "Sửa tài khoản";
    Layout = "_LayoutDashboard";
}

<div class="p-4 p-md-5">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-edurag-ghost mb-3 d-inline-flex align-items-center gap-1">
            @{ ViewData["Icon"] = "arrow-left"; ViewData["IconSize"] = "14"; }
            @await Html.PartialAsync("_Icons")
            Quay lại
        </a>
        <h1 class="font-display fs-2 fw-bold mb-1">Sửa tài khoản</h1>
        <p class="text-muted-edurag mb-0">Cập nhật vai trò, trạng thái, môn học hoặc mật khẩu mới.</p>
    </div>

    <div class="edurag-card p-4 p-md-5" style="max-width:720px;">
        <form asp-action="Edit" method="post" class="vstack gap-3">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="AccountId" />

            <div>
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Password" class="form-label fw-semibold">Mật khẩu mới</label>
                <input asp-for="Password" type="password" class="form-control" />
                <div class="form-text text-muted-edurag">Để trống nếu giữ mật khẩu hiện tại.</div>
            </div>

            <div>
                <label asp-for="FullName" class="form-label fw-semibold">Họ và tên</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Role" class="form-label fw-semibold">Vai trò</label>
                <select asp-for="Role" class="form-select">
                    <option value="1">Student</option>
                    <option value="2">Teacher</option>
                </select>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="CourseId" class="form-label fw-semibold">Môn học gán</label>
                <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select">
                    <option value="">Không gán</option>
                </select>
                <div class="form-text text-muted-edurag">Bắt buộc với Teacher. Student không được gán môn.</div>
            </div>

            <div class="form-check">
                <input asp-for="Status" type="checkbox" class="form-check-input" />
                <label asp-for="Status" class="form-check-label">Tài khoản hoạt động</label>
            </div>

            <div class="d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-edurag-warm">Lưu</button>
                <a asp-action="Index" class="btn btn-edurag-outline">Huỷ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
